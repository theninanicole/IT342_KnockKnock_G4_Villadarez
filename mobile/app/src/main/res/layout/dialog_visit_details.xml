<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:gravity="bottom"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/visitDetailsSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_new_visit_sheet"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Visit Details"
                android:textColor="#2663EB"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnCloseModal"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Close"
                android:src="@drawable/ic_close_circle" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/detailsScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="false"
            android:scrollbarStyle="insideOverlay">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/VisitDetailsLabel"
                    android:text="Condominium" />

                <TextView
                    android:id="@+id/tvCondoNameDetail"
                    style="@style/VisitDetailsValue"
                    android:text="One Archer's Place" />

                <TextView
                    style="@style/VisitDetailsLabel"
                    android:text="Unit Number" />

                <TextView
                    android:id="@+id/tvUnitNumberDetail"
                    style="@style/VisitDetailsValue"
                    android:text="12I" />

                <TextView
                    style="@style/VisitDetailsLabel"
                    android:text="Date of Visit" />

                <TextView
                    android:id="@+id/tvVisitDateDetail"
                    style="@style/VisitDetailsValue"
                    android:text="2026-03-12" />

                <TextView
                    style="@style/VisitDetailsLabel"
                    android:text="Purpose of Visit" />

                <TextView
                    android:id="@+id/tvPurposeDetail"
                    style="@style/VisitDetailsValue"
                    android:text="Visiting family" />

                <TextView
                    style="@style/VisitDetailsLabel"
                    android:text="ID" />

                <LinearLayout
                    android:id="@+id/idFileRow"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="22dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_file_icon">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="ID document"
                            android:src="@drawable/ic_document"
                            android:tint="#2563EB" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvIDDetail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:ellipsize="middle"
                        android:singleLine="true"
                        android:text="Loading file..."
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/qrSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="36dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="20dp"
                        android:background="#F1F5F9" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Entry QR Code"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/ivQRCode"
                        android:layout_width="154dp"
                        android:layout_height="154dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_input_field"
                        android:contentDescription="Entry QR Code"
                        android:elevation="2dp"
                        android:padding="18dp"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="This QR code can be scanned for quick check-in."
                        android:textColor="#A7B0BF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnSendQrEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="2dp"
                        android:drawableStart="@drawable/ic_email"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:text="Send to Email"
                        android:textColor="#2563EB"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="18dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp"
                        android:background="#F1F5F9" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnCancelVisit"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical|start"
                android:text="Cancel Visit"
                android:textColor="#FF3045"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:minWidth="72dp"
                android:text="Edit"
                android:textColor="#2563EB"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnGenerateQR"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:drawableStart="@drawable/ic_qr"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:minWidth="132dp"
                android:text="Generate QR"
                android:textColor="#2563EB"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
