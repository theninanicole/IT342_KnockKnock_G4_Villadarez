<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_account"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/scrollAccount"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="44dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/tvAccountTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account"
                    android:textColor="#000000"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/profileCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_profile_card"
                    android:clipToOutline="true"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="198dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="138dp"
                            android:background="@drawable/bg_profile_banner" />

                        <TextView
                            android:id="@+id/tvInitials"
                            android:layout_width="92dp"
                            android:layout_height="92dp"
                            android:layout_gravity="start|bottom"
                            android:layout_marginStart="22dp"
                            android:layout_marginBottom="18dp"
                            android:background="@drawable/bg_profile_avatar"
                            android:elevation="6dp"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="27sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|bottom"
                            android:layout_marginStart="128dp"
                            android:layout_marginEnd="110dp"
                            android:layout_marginBottom="37dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvProfileHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Profile"
                                android:textColor="#0F172A"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvProfileSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Update your personal details."
                                android:textColor="#64748B"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnEditProfile"
                            android:layout_width="78dp"
                            android:layout_height="48dp"
                            android:layout_gravity="end|bottom"
                            android:layout_marginEnd="20dp"
                            android:layout_marginBottom="42dp"
                            android:background="@drawable/bg_profile_action_button"
                            android:clickable="true"
                            android:elevation="3dp"
                            android:focusable="true"
                            android:gravity="center"
                            android:paddingHorizontal="12dp"
                            android:text="Edit"
                            android:textColor="#334155"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/editActions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|bottom"
                            android:layout_marginEnd="20dp"
                            android:layout_marginBottom="42dp"
                            android:gravity="end"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/btnCancelEdit"
                                android:layout_width="86dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_profile_action_button"
                                android:clickable="true"
                                android:elevation="3dp"
                                android:focusable="true"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Cancel"
                                android:textColor="#334155"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnSaveProfile"
                                android:layout_width="74dp"
                                android:layout_height="48dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_profile_save_button"
                                android:clickable="true"
                                android:elevation="3dp"
                                android:focusable="true"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Save"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="22dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:text="Full name"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etFullName"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_input_field"
                            android:inputType="textPersonName"
                            android:paddingHorizontal="14dp"
                            android:textColor="#334155"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Contact number"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etContactNumber"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_input_field"
                            android:inputType="phone"
                            android:paddingHorizontal="14dp"
                            android:textColor="#334155"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Email address"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_profile_readonly"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="14dp"
                            android:textColor="#64748B"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Account created"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvJoinedDate"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_profile_readonly"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="14dp"
                            android:textColor="#64748B"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/passwordCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_profile_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change Password"
                        android:textColor="#0F172A"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etCurrentPassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Current password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="14dp"
                        android:textColor="#334155"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/etNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="New password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="14dp"
                        android:textColor="#334155"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Confirm new password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="14dp"
                        android:textColor="#334155"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/btnUpdatePassword"
                        android:layout_width="220dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_password_action_button"
                        android:clickable="true"
                        android:elevation="2dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="Update Password"
                        android:textColor="#334155"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ProgressBar
            android:id="@+id/progressAccount"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_home"
            android:drawableTint="@color/nav_unselected"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="Home"
            android:textColor="@color/nav_unselected"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tabMyVisits"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_visits"
            android:drawableTint="@color/nav_unselected"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="My Visits"
            android:textColor="@color/nav_unselected"
            android:textSize="12sp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tabNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/ic_notifications"
                android:drawableTint="@color/nav_unselected"
                android:drawablePadding="4dp"
                android:gravity="center"
                android:text="Notifications"
                android:textColor="@color/nav_unselected"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/badgeNotificationCount"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_notification_badge"
                android:gravity="center"
                android:minWidth="18dp"
                android:paddingHorizontal="5dp"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:translationX="13dp"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tabAccount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_person"
            android:drawableTint="@color/nav_unselected"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="Account"
            android:textColor="@color/nav_unselected"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tabLogout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_log_out"
            android:drawableTint="@color/nav_unselected"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="Log out"
            android:textColor="@color/nav_unselected"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
