<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:gravity="bottom"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_new_visit_sheet"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edit Visit"
                android:textColor="#2663EB"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnCloseEditVisit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Close"
                android:src="@drawable/ic_close_circle" />
        </LinearLayout>

        <TextView
            style="@style/VisitDetailsLabel"
            android:text="Unit Number" />

        <EditText
            android:id="@+id/etEditUnitNumber"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_input_field"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#64748B"
            android:textSize="15sp" />

        <TextView
            style="@style/VisitDetailsLabel"
            android:text="Date of Visit" />

        <EditText
            android:id="@+id/etEditVisitDate"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_input_field"
            android:hint="YYYY-MM-DD"
            android:inputType="date"
            android:paddingHorizontal="12dp"
            android:textColor="#64748B"
            android:textColorHint="#CBD5E1"
            android:textSize="15sp" />

        <TextView
            style="@style/VisitDetailsLabel"
            android:text="Purpose of Visit" />

        <EditText
            android:id="@+id/etEditPurpose"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_input_field"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:padding="12dp"
            android:textColor="#64748B"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnSaveEditVisit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#2563EB"
            android:text="Save Changes"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
