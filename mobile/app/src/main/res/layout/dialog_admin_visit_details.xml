<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_profile_card"
    android:orientation="vertical"
    android:paddingTop="26dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visit Details"
                android:textColor="@color/brand_blue_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReferenceNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="×"
            android:textColor="#94A3B8"
            android:textSize="32sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="18dp"
        android:paddingBottom="24dp">

        <TextView
            style="@style/AdminModalLabel"
            android:text="Visitor" />

        <TextView
            android:id="@+id/tvVisitorName"
            style="@style/AdminModalValue"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/AdminModalLabel"
                    android:text="Unit Number" />

                <TextView
                    android:id="@+id/tvUnitNumber"
                    style="@style/AdminModalValue" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/AdminModalLabel"
                    android:text="Date of Visit" />

                <TextView
                    android:id="@+id/tvVisitDate"
                    style="@style/AdminModalValue" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/AdminModalLabel"
            android:layout_marginTop="18dp"
            android:text="Purpose of Visit" />

        <TextView
            android:id="@+id/tvPurpose"
            style="@style/AdminModalValue"
            android:layout_marginBottom="18dp" />

        <TextView
            style="@style/AdminModalLabel"
            android:text="ID" />

        <LinearLayout
            android:id="@+id/fileRow"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_profile_readonly"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <TextView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_file_icon"
                android:drawableTop="@drawable/ic_document"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#0F172A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnViewFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/securityChecklist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_security_checklist"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security Checklist"
                android:textColor="#F97316"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Verify that the person checking in matches the individual shown in the uploaded ID."
                android:textColor="#F97316"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/footerDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0" />

    <TextView
        android:id="@+id/btnCheckIn"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="22dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_profile_save_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="Check In"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
