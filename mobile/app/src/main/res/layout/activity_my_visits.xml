<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_my_visits"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvSectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Visits"
            android:textColor="#0F172A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvVisits"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                android:scrollbars="vertical" />

            <ProgressBar
                android:id="@+id/progressVisits"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvEmptyVisits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="#F8FAFC"
                android:gravity="center"
                android:padding="20dp"
                android:text="No visits found."
                android:textColor="#64748B"
                android:textSize="14sp"
                android:textStyle="italic"
                android:visibility="gone" />

        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_home"
            android:drawableTint="@color/nav_unselected"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="Home"
            android:textColor="@color/nav_unselected"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tabMyVisits"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_visits"
            android:drawableTint="@color/nav_unselected"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="My Visits"
            android:textColor="@color/nav_unselected"
            android:textSize="12sp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tabNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/ic_notifications"
                android:drawableTint="@color/nav_unselected"
                android:drawablePadding="4dp"
                android:gravity="center"
                android:text="Notifications"
                android:textColor="@color/nav_unselected"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/badgeNotificationCount"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_notification_badge"
                android:gravity="center"
                android:minWidth="18dp"
                android:paddingHorizontal="5dp"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:translationX="13dp"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tabAccount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_person"
            android:drawableTint="@color/nav_unselected"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="Account"
            android:textColor="@color/nav_unselected"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tabLogout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_log_out"
            android:drawableTint="@color/nav_unselected"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="Log out"
            android:textColor="@color/nav_unselected"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
