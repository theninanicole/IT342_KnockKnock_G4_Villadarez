<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="edu.villadarez.knockknock">
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KnockKnock"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".features.auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".features.visit.VisitorDashboardActivity"
            android:exported="true" />

        <activity
            android:name=".features.visit.MyVisitsActivity"
            android:exported="true" />

        <activity
            android:name=".features.visit.NotificationsActivity"
            android:exported="true" />

        <activity
            android:name=".features.visit.AccountActivity"
            android:exported="true" />

        <activity
            android:name=".features.admin.AdminDashboardActivity"
            android:exported="true" />

        <activity
            android:name=".features.admin.AdminAllVisitsActivity"
            android:exported="true" />

        <activity
            android:name=".features.admin.AdminStatusHistoryActivity"
            android:exported="true" />

        <activity android:name=".features.auth.RegisterActivity"
            android:exported="true" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

    </application>
</manifest>
